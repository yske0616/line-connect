# ─── GHL Marketplace App ──────────────────────────────────────────────────
GHL_APP_CLIENT_ID=your_ghl_client_id_here
GHL_APP_CLIENT_SECRET=your_ghl_client_secret_here
GHL_APP_REDIRECT_URI=https://your-app.up.railway.app/oauth/callback

# ─── GHL Conversation Provider (Unified Inbox) ────────────────────────────
# Get this from: GHL Developer Portal → My Apps → [your app] → Conversation Providers
# Set Delivery URL to: https://your-app.up.railway.app/conversations/outbound
GHL_CONVERSATION_PROVIDER_ID=your_conversation_provider_id_here

# ─── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/line_connect

# ─── Encryption ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-random-32-character-string-here

# ─── Server ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
APP_BASE_URL=https://your-app.up.railway.app
